{
  // ================================================================
  // AEGIS — VS Code Settings
  // Maximised for GitHub Copilot agent-mode software engineering.
  // Human role: AI orchestrator. AI role: do the typing.
  // ================================================================

  // ── GitHub Copilot Core ─────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "yaml": true,
    "toml": true
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.editor.enableCodeActions": true,
  "github.copilot.inlineSuggest.suppressSuggestions": false,
  "github.copilot.nextEditSuggestions.enabled": true,

  // ── Copilot Chat ────────────────────────────────────────────────
  "github.copilot.chat.welcomeMessage": "never",
  "github.copilot.chat.localeOverride": "en",
  "github.copilot.chat.useProjectTemplates": false,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.setupTests.enabled": true,
  "github.copilot.chat.fixTestFailure.enabled": true,
  "github.copilot.chat.startDebugging.enabled": true,
  "github.copilot.chat.reviewSelection.enabled": true,
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "text": "Review for: determinism violations, silent exception handling, forward imports, missing type annotations, global mutable state, magic numbers, and missing tests. Flag any anti-pattern listed in skills.md §7."
    }
  ],
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Format: <type>(<scope>): <imperative summary>\n\n<body: what and why, not how>\n\nRefs: #<issue>\nBreaking: yes/no\nTests: added|updated|none\n\nTypes: feat|fix|refactor|test|docs|chore|perf. Scopes: intent|validation|planning|audit|gate|contracts."
    }
  ],
  "github.copilot.chat.codeGeneration.instructions": [
    { "file": ".github/copilot-instructions.md" },
    { "file": "skills.md" }
  ],
  "github.copilot.chat.testGeneration.instructions": [
    {
      "text": "Generate pytest tests. For every pure function also add a Hypothesis property-based invariant test in tests/invariants/. Follow naming: test_{what}_{condition}_{expected}. Fixtures in conftest.py only. No shared mutable state between tests. Use pytest.mark.parametrize for multi-case tests."
    }
  ],

  // ── Copilot Agent / Edits Mode ───────────────────────────────────
  "github.copilot.chat.edits.enabled": true,
  "chat.agent.enabled": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.search.semanticTextResults": true,
  "github.copilot.chat.implicitContext.instructions": true,

  // ── Editor — Optimised for AI-Driven Workflow ────────────────────
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.inlineSuggest.syntaxHighlightingEnabled": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "explicit",
    "source.organizeImports.ruff": "explicit"
  },
  "editor.rulers": [88, 120],
  "editor.wordWrap": "off",
  "editor.linkedEditing": true,
  "editor.suggest.preview": true,
  "editor.suggest.insertMode": "replace",
  "editor.acceptSuggestionOnEnter": "on",
  "editor.quickSuggestionsDelay": 0,
  "editor.parameterHints.enabled": true,
  "editor.hover.delay": 300,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.occurrencesHighlight": "multiFile",

  // ── Python ───────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoSearchPaths": true,
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    { "name": "aegis", "depth": 10, "includeAllSymbols": true }
  ],
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.callArgumentNames": "all",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingTypeArgument": "warning",
    "reportUnknownMemberType": "warning"
  },

  // ── Ruff ────────────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ruff.organizeImports": true,
  "ruff.fixAll": true,

  // ── Testing ─────────────────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests/", "--tb=short", "-q", "--no-header"],
  "testing.coverageBarThresholds": { "red": 0, "yellow": 85, "green": 90 },
  "testing.showCoverageInExplorer": true,
  "testing.automaticallyOpenPeekView": "failureInVisibleDocument",
  "testing.defaultGutterClickAction": "run",

  // ── Git ─────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.autofetchPeriod": 60,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.postCommitCommand": "none",
  "scm.inputBoxHeight": 6,
  "scm.inputBoxScrollIndicator": "always",

  // ── File Explorer ────────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/dist": true,
    "**/build": true,
    "**/*.egg-info": true
  },
  "files.watcherExclude": {
    "**/__pycache__/**": true,
    "**/.venv/**": true,
    "**/dist/**": true
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.associations": {
    "*.prompt.md": "markdown",
    "pyproject.toml": "toml"
  },

  // ── Search ───────────────────────────────────────────────────────
  "search.exclude": {
    "**/.venv": true,
    "**/dist": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true
  },
  "search.useIgnoreFiles": true,
  "search.smartCase": true,

  // ── Terminal ────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.env.linux": { "PYTHONPATH": "${workspaceFolder}/src" },
  "terminal.integrated.env.osx": { "PYTHONPATH": "${workspaceFolder}/src" },
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.copyOnSelection": true,

  // ── Workbench ────────────────────────────────────────────────────
  "workbench.editor.enablePreview": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 12,
  "workbench.editor.revealIfOpen": true,
  "workbench.tree.indent": 16,
  "workbench.startupEditor": "none",
  "breadcrumbs.enabled": true,
  "outline.showVariables": true,
  "problems.sortOrder": "severity",
  "problems.showCurrentInStatus": true,
  "chat.commandCenter.enabled": true,

  // ── Markdown ────────────────────────────────────────────────────
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": { "other": "on", "comments": "off", "strings": "off" }
  },
  "markdown.preview.breaks": true
}